            "feature_fc_dims": [64, 64],
            "rule_fc_dims": [64, 64]
        },
        "reg_params": {
            "use_mask": false,
            "interv_mask_init": 0.9,
            "adjacency_init": 0.7,
            "flip_prob_init": 0.1,
            "flip_prob_final": 0.0,
            "lambda_M_init": 0.0,
            "lambda_M_final": 0.01,
            "lambda_I_init": 0.0,
            "lambda_I_final": 0.01,
            "mask_threshold": 0.5,
            "reg_annealing_start": 20000,
            "reg_annealing_end": 20001
