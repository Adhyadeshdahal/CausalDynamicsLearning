            "use_current_state": true,
            "fc_dims": [64, 64],
            "activations": ["relu", "relu"],

            "planner_type": "cem",
            "std_scale": 1.0,

            "n_horizon_step": 3,
            "n_iter": 5,
            "n_candidate": 64,
            "n_top_candidate": 16,

            "action_noise": 0.01,
