            "prioritized_buffer": false
        }
    },

    "encoder_params": {
        "encoder_type": "identity"
    },

"inference_params": {
        "n_pred_step": 1,
        "batch_size": 64,
        "lr": 1e-4,
        "train_prop": 0.9,
        "residual": true,
        "log_std_min": -5,
        "log_std_max": 2,
        "grad_clip_norm": 20001,
        "cmi_params": {
            "feature_fc_dims": [64, 64],
