{
    "info": "oran_conflict_rl",

    "obs_keys": [
        "param0","param1","param2","param3","param4","param5","param6",
        "kpi0","kpi1","kpi2","kpi3"
    ],

    "goal_keys": [],

    "seed": 0,
    "cuda_id": 0,

    "continuous_state": true,

    "env_params": {
        "env_name": "Conflict",
        "num_env": 1,

        "conflict_env_params": {
            "num_bins": 10,
            "max_steps": 50
        }
    },

    "training_params": {
        "inference_algo": "cmi",
        "rl_algo": "model_based",

        "load_inference": "",
        "load_model_based": "",
        "load_policy": "",
        "load_replay_buffer": "",

        "total_steps": 20000,
        "init_steps": 3000,

        "collect_env_step": true,

        "inference_gradient_steps": 1,
        "policy_gradient_steps": 1,

        "saving_freq": 5000,
        "plot_freq": 10000,

